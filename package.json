{
  "name": "ai-sales-agent",
  "version": "1.0.0",
  "description": "Intelligent Conversational Support & Sales Agent for E-Commerce",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:widget": "vite build --config widget/vite.config.ts",
    "build:all": "npm run build && npm run build:widget",
    "start": "node dist/index.js",
    "db:migrate": "psql $DATABASE_URL -f src/models/migrations/001_initial_schema.sql",
    "lint": "tsc --noEmit"
  },
  "author": "Brian Gacheru Mungai",
  "license": "MIT",
  "dependencies": {
    "@shopify/shopify-api": "^12.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "multer": "^2.0.2",
    "openai": "^6.24.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.18.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "vite": "^8.0.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/json-schema": "^7.0.15",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.2.3",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.9",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
